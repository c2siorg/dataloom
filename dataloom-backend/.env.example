# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/dataloom"

# CORS allowed origins (JSON array)
CORS_ORIGINS=["http://localhost:3200"]

# Directory for uploaded CSV files
UPLOAD_DIR=uploads

# Maximum file upload size in bytes (default: 10MB)
MAX_UPLOAD_SIZE_BYTES=10485760

# Debug mode
DEBUG=false

# Secret key for signing JWT auth tokens (REQUIRED, generate with: openssl rand -hex 32)
JWT_SECRET=

# JWT signing algorithm
JWT_ALGORITHM=HS256

# Auth token lifetime in hours
JWT_EXPIRY_HOURS=24

# Send the auth cookie only over HTTPS. Set to false for local http development.
COOKIE_SECURE=true

# SMTP configuration for sending emails (e.g., password reset, notifications)
SMTP_HOST=smtp.gmail.com

# SMTP port (587 for TLS)
SMTP_PORT=587

# SMTP username (your email address)
SMTP_USERNAME=your-smtp-username

# SMTP password (your email password or app-specific password)
SMTP_PASSWORD=your-smtp-password

# Email address to use in the "From" field when sending emails
SMTP_FROM_EMAIL=your-email@domain.com

# Frontend URL
FRONTEND_URL=http://localhost:3200
