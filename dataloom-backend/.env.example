# PostgreSQL Database Credentials (used by Docker Compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dataloom

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/dataloom"

# CORS allowed origins (JSON array)
CORS_ORIGINS=["http://localhost:3200"]

# Docker: set to /app/uploads to match volume mount
UPLOAD_DIR=/app/uploads

# Maximum file upload size in bytes (default: 10MB)
MAX_UPLOAD_SIZE_BYTES=10485760

# Debug mode
DEBUG=false
