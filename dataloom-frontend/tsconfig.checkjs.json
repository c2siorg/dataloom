{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "strict": false,
    "noEmit": true
  },
  "include": [
    "src/api/**/*.js",
    "src/hooks/useProject.js",
    "src/hooks/useTransform.js",
    "src/vite-env.d.ts"
  ],
  "exclude": [
    "src/**/__tests__/**",
    "src/**/*.test.js",
    "src/**/*.test.jsx"
  ]
}